{
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/**/*.mjs": {
      "includeFiles": "data/matches.json"
    }
  },
  "headers": [
    {
      "source": "/data/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300"
        }
      ]
    }
  ]
}
